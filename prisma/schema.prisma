// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ADMIN
model Admin {
  id        Int      @id @default(autoincrement())
  nom       String
  email     String   @unique
  password  String   // hashé avec bcrypt
  createdAt DateTime @default(now())
}

// OFFRE D'EMPLOI
model Offre {
  id              Int             @id @default(autoincrement())
  titre           String
  description     String
  lieu            String
  typeContrat     TypeContrat     @default(CDI)
  categorie       String?
  salaire         String?
  dateExpiration  DateTime?
  statut          StatutOffre     @default(ACTIVE)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  candidatures    Candidature[]
}

enum TypeContrat {
  CDI
  CDD
  STAGE
  FREELANCE
  ALTERNANCE
}

enum StatutOffre {
  ACTIVE
  FERMEE
  BROUILLON
}

// CANDIDAT
model Candidat {
  id           Int           @id @default(autoincrement())
  nom          String
  prenom       String
  email        String        @unique
  telephone    String?
  createdAt    DateTime      @default(now())

  candidatures Candidature[]
}

// CANDIDATURE 
model Candidature {
  id                Int              @id @default(autoincrement())
  offreId           Int
  candidatId        Int
  cvPath            String           // chemin du fichier CV uploadé
  lettreMotivation  String?          // texte ou chemin fichier
  statut            StatutCandidature @default(EN_ATTENTE)
  dateCandidature   DateTime         @default(now())

  offre             Offre            @relation(fields: [offreId], references: [id], onDelete: Cascade)
  candidat          Candidat         @relation(fields: [candidatId], references: [id], onDelete: Cascade)

  @@unique([offreId, candidatId]) // empêche un candidat de postuler 2x à la même offre
}

enum StatutCandidature {
  EN_ATTENTE
  ENTRETIEN
  ACCEPTEE
  REFUSEE
}